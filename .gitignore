# --- Generated monthly batches (recreated by the data-prep script) ---
data/batches/

# --- mlflow local tracking store + artifacts ---
mlruns/
mlartifacts/
mlflow.db

# --- served-model prediction logs (regenerated at runtime) ---
logs/

# --- OS / editor cruft ---
.DS_Store
.idea/
.vscode/

# --- Claude Code machine-local settings ---
.claude/settings.local.json

# --- Private working notes (not for the public repo) ---
SPEC.md
notes.md
